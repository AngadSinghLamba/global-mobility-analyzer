# =============================================================================
# Global Mobility Analyzer — Environment Variables
# =============================================================================
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- Google AI Studio (Gemini 3) ---
# Get your free API key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-ai-studio-key

# --- Azure AI Search (Free Tier) ---
# Create a free search service: https://portal.azure.com
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_API_KEY=your-azure-search-admin-key
AZURE_SEARCH_INDEX_NAME=visa-knowledge-base

# --- Logging ---
LOG_LEVEL=INFO

# --- Cache ---
# Local SQLite cache for LLM responses and verification results
CACHE_TTL_HOURS=24
